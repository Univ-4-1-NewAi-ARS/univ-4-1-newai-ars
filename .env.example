APP_ENV=local
LOG_LEVEL=INFO
REPOSITORY_PROVIDER=postgres

POSTGRES_DB=ars_survey
POSTGRES_USER=ars_user
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379
SURVEY_DIR=/surveys

ORCHESTRATOR_PORT=8000
ORCHESTRATOR_BASE_URL=http://ai-orchestrator:8000

DISCORD_BOT_TOKEN=replace_me
DISCORD_GUILD_ID=replace_me
DISCORD_VOICE_CHANNEL_ID=replace_me
DISCORD_TEXT_CHANNEL_ID=replace_me
DISCORD_MOCK_MODE=true

LLM_PROVIDER=mock
LLM_BASE_URL=http://host.docker.internal:11434
LLM_MODEL=qwen2.5:7b-instruct
LLM_TIMEOUT_SEC=10
LLM_PARSE_RETRY_COUNT=2
LLM_USE_API_FALLBACK=true
OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-4.1-mini

STT_PROVIDER=mock
STT_BASE_URL=http://stt-service:8100
STT_MODEL=small
STT_LANGUAGE=ko
STT_USE_API_FALLBACK=false

TTS_PROVIDER=cached_file
TTS_BASE_URL=http://tts-service:8200
TTS_VOICE=ko_default
TTS_LANGUAGE=ko
TTS_USE_API_FALLBACK=false

SAVE_RAW_AUDIO=true
SAVE_TRANSCRIPT=true
RAW_AUDIO_RETENTION_DAYS=7
TRANSCRIPT_RETENTION_DAYS=30

ANSWER_TIMEOUT_SEC=8
SILENCE_TIMEOUT_SEC=2
MAX_RETRY_PER_QUESTION=2

DASHBOARD_PORT=8501
ADMINER_PORT=8080
