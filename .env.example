APP_ENV=local
LOG_LEVEL=INFO
REPOSITORY_PROVIDER=postgres

POSTGRES_DB=ars_survey
POSTGRES_USER=ars_user
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379
SURVEY_DIR=/surveys
AUDIO_DIR=/data/audio

ORCHESTRATOR_PORT=8000
ORCHESTRATOR_BASE_URL=http://ai-orchestrator:8000
# Discord bot HTTP client timeout for orchestrator calls. Audio answers run
# STT (whisper) + LLM (ollama) on CPU, so keep this >= the orchestrator's
# LLM_TIMEOUT_SEC plus cold model-load headroom.
ORCHESTRATOR_TIMEOUT_SEC=120

DISCORD_BOT_TOKEN=replace_me
DISCORD_GUILD_ID=replace_me
DISCORD_VOICE_CHANNEL_ID=replace_me
DISCORD_TEXT_CHANNEL_ID=replace_me
DISCORD_MOCK_MODE=true
DISCORD_COMMAND_PREFIX=!survey
DEFAULT_SURVEY_ID=campus_opinion_survey

LLM_PROVIDER=ollama
LLM_BASE_URL=http://host.docker.internal:11434
LLM_MODEL=gemma3:4b
LLM_TIMEOUT_SEC=45
LLM_PARSE_RETRY_COUNT=2
LLM_USE_API_FALLBACK=true
LLM_USE_MOCK_FALLBACK=true
OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-4.1-mini

STT_PROVIDER=local_whisper
STT_BASE_URL=http://stt-service:8100
STT_MODEL=small
STT_LANGUAGE=ko
STT_USE_API_FALLBACK=false
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8
STT_MODEL_DIR=/models/whisper
STT_USE_MOCK_FALLBACK=true

TTS_PROVIDER=local_espeak
TTS_BASE_URL=http://tts-service:8200
TTS_VOICE=ko_default
TTS_LANGUAGE=ko
TTS_USE_API_FALLBACK=false
TTS_FALLBACK_PROVIDER=cached_file
TTS_USE_CACHED_FALLBACK=true
TTS_CACHE_ENABLED=true
TTS_ESPEAK_VOICE=ko
PIPER_BIN=piper
PIPER_MODEL_PATH=/models/piper/piper-kss-korean.onnx

SAVE_RAW_AUDIO=true
SAVE_TRANSCRIPT=true
RAW_AUDIO_RETENTION_DAYS=7
TRANSCRIPT_RETENTION_DAYS=30
PARTICIPANT_HASH_SALT=replace_me

ANSWER_TIMEOUT_SEC=8
SILENCE_TIMEOUT_SEC=2
MAX_RETRY_PER_QUESTION=2
# Honor needs_retry for free_text answers. Default false: open-ended opinions are
# always accepted, so a local LLM flagging needs_retry won't loop the question.
FREE_TEXT_RETRY_ENABLED=false
VOICE_SILENCE_TIMEOUT_SEC=2
VOICE_MAX_RECORD_SEC=15

DASHBOARD_PORT=8501
REPORT_DIR=/reports
ADMINER_PORT=8080
